<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Lock_Record_While_Pending</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Approval_Status__c, &quot;Approved&quot;),
    NOT(ISCHANGED(Approval_Status__c))
)</errorConditionFormula>
    <errorMessage>This enrollment record is currently locked under management review and cannot be edited</errorMessage>
</ValidationRule>
